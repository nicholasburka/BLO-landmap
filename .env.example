# Frontend build-time env (Vite inlines VITE_* values into the bundle —
# anything here is visible to end users; only publishable keys belong).

# Mapbox public access token (pk.*)
VITE_MAPBOX_ACCESS_TOKEN=

# RentCast API key used for the property-listings panel. Note: this ships
# in the client bundle. If listings ever need a private key, proxy the
# calls through the backend instead.
VITE_RENTCAST_API_KEY=

# URL of the Express LLM backend, e.g. https://blo-api.up.railway.app
# Optional in local dev (falls back to http://localhost:3001); REQUIRED
# on Netlify — without it the AI features are disabled in the built app.
VITE_API_URL=

# Set to true ONLY on the staging Netlify site — renders the "Staging
# access" pill (see STAGING.md). Leave unset on prod.
# VITE_STAGING_GATE_ENABLED=true
