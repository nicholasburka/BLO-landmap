ANTHROPIC_API_KEY=
BETA_PASSWORD=
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
PORT=3001

# Daily token budget guards (defaults: 200_000 total, 15_000 per IP).
# Override only if you know what you're changing.
# DAILY_BUDGET_TOKENS=200000
# DAILY_BUDGET_TOKENS_PER_IP=15000

# Local-dev escape hatch — disables both daily caps so local testing
# isn't blocked by the per-IP 15k limit. Usage is still recorded for
# observability, but limits are not enforced. NEVER set this in
# production deployments.
# BUDGET_BYPASS=true
