ANTHROPIC_API_KEY=

# REQUIRED — signing key for session tokens. Must be a dedicated random
# string of at least 32 characters (NOT a human password). The server
# refuses to boot without it. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_HMAC_SECRET=

BETA_PASSWORD=
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
PORT=3001

# Set on every production deployment. Hardens error responses and
# force-disables BUDGET_BYPASS.
# NODE_ENV=production

# Number of proxy hops between the client and this server (Express
# `trust proxy`). 1 = single proxy (Railway/Render direct), 2 = CDN in
# front of that. Must match the real topology or per-IP limits are
# spoofable. Defaults to 1.
# TRUST_PROXY_HOPS=1

# Optional Postgres connection string for the usage dashboard (/dashboard).
# When set, per-request usage is persisted and survives redeploys; when
# unset, the dashboard still works but only shows data since the last
# restart. Any managed Postgres works (Neon/Railway/Render/Supabase).
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Daily token budget guards (defaults: 200_000 total, 15_000 per IP).
# Override only if you know what you're changing.
# DAILY_BUDGET_TOKENS=200000
# DAILY_BUDGET_TOKENS_PER_IP=15000

# Local-dev escape hatch — disables both daily caps so local testing
# isn't blocked by the per-IP 15k limit. Usage is still recorded for
# observability, but limits are not enforced. Ignored (with a warning)
# when NODE_ENV=production.
# BUDGET_BYPASS=true

# Staging-tier password. When set, users who POST this value to
# /api/auth receive a `staging`-tier token that bypasses the daily
# cap. Lets PM testers exercise the conversational layer on a shared
# backend without burning into the prod token budget. Leave unset on
# pure-prod deployments — the upgrade path simply won't exist.
# A staging-tier token is also what unlocks GET /api/health/usage.
# STAGING_PASSWORD=
